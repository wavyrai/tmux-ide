{
  "name": "tmux-ide",
  "version": "2.1.5",
  "description": "Turn any project into a tmux-powered terminal IDE with a simple ide.yml",
  "type": "module",
  "bin": {
    "tmux-ide": "bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "skill",
    "templates",
    "dashboard/out"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "build:cli": "node scripts/build-cli.mjs",
    "build:dashboard": "cd dashboard && npx next build",
    "dev:solid": "cd dashboard-solid && pnpm dev",
    "build:solid": "cd dashboard-solid && pnpm build",
    "test:solid": "cd dashboard-solid && pnpm test",
    "prepublishOnly": "npm run build:cli && npm run build:dashboard",
    "typecheck": "tsc --noEmit",
    "dev": "node bin/cli.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "dev:bun": "bun bin/cli.ts",
    "dev:bun:test": "bun test",
    "dev:bun:test:unit": "bun test src/ --ignore 'src/integration.test.ts'",
    "dev:bun:test:integration": "bun test src/integration.test.ts",
    "dev:bun:test:stress": "bun scripts/stress-test.ts",
    "lint": "eslint bin scripts packages/contracts/src packages/tmux-bridge/src packages/daemon/src packages/v2-solid-widgets/src packages/chat-solid/src && pnpm run check:silo-mounts",
    "lint:workspace": "turbo run lint && pnpm run check:silo-mounts",
    "check:silo-mounts": "bash scripts/check-silo-mounts.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:workspace": "turbo run build",
    "typecheck:workspace": "turbo run typecheck",
    "docs:build": "turbo run build --filter=@tmux-ide/docs",
    "pack:check": "npm pack --dry-run --cache /tmp/tmux-ide-npm-cache > /dev/null",
    "check": "pnpm run lint:workspace && pnpm run format:check && pnpm run typecheck && pnpm run dev:bun:test:unit && pnpm run docs:build && pnpm run pack:check",
    "postinstall": "node scripts/postinstall.js",
    "test:dashboard": "cd dashboard && pnpm test",
    "test:e2e": "playwright test",
    "docs": "turbo run dev --filter=@tmux-ide/docs"
  },
  "keywords": [
    "tmux",
    "ide",
    "terminal",
    "workspace",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wavyrai/tmux-ide.git"
  },
  "homepage": "https://github.com/wavyrai/tmux-ide#readme",
  "bugs": {
    "url": "https://github.com/wavyrai/tmux-ide/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.21.0",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@opentui/core": "^0.1.88",
    "@opentui/core-darwin-arm64": "^0.1.88",
    "@opentui/solid": "^0.1.88",
    "@parcel/watcher": "^2.5.6",
    "@types/ws": "^8.18.1",
    "chokidar": "^5.0.0",
    "hono": "^4.12.8",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "node-pty": "1.2.0-beta.12",
    "solid-js": "^1.9.11",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tsconfig/bun": "^1.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "0.27.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3"
  }
}
