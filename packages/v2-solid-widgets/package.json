{
  "name": "@tmux-ide/v2-solid-widgets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/v2-solid-widgets.js",
  "module": "dist/v2-solid-widgets.js",
  "types": "dist/v2-solid-widgets.d.ts",
