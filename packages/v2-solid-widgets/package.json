    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^25.5.0",
    "happy-dom": "^20.8.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.1.0"
  }
