# dependencies
node_modules
docs/node_modules

# build output
.next
docs/.next
dashboard/out

# environment files
.env.local
.env*.local

# turbo cache
.turbo

# local package artifacts
*.tgz

# local OS files
.DS_Store

# local tool settings
.claude/
ide.yml

# local authoring context
context/

# local planning artifacts (repo-root only; do NOT match nested
# directories like dashboard/components/plans/)
/plans/

# local task board
.tasks/

# local agent context (per-project skills + library); never ships to npm
.tmux-ide/

# Orchestrator worktrees
.worktrees/

# Stale per-goal screenshots and ad-hoc handoff notes — keep out of the public tree
HANDOFF.md
goal-*-working-state.gif
goal-*-commit-readiness.md
app-electron/

# TypeScript build output
dist/

# Electron build outputs (binaries exceed GitHub 100MB limit)
app-electron/release/
app-electron/dist-electron/
app-electron/build/
app-electron/node_modules/
app-electron/.turbo/
app-electron/.tasks/
app-electron/.tmux-ide/

# Privately-licensed assets (Berkeley Mono, etc.) — never bundled in OSS
dashboard/public/fonts/private/*
!dashboard/public/fonts/private/NOTICE.md
!dashboard/public/fonts/private/.gitkeep

# Playwright artifacts
test-results/
playwright-report/

# Vitest v8 coverage reports (per-package, written by `pnpm test --coverage`)
coverage/
**/coverage/

# Stray npm lockfiles (project uses pnpm)
package-lock.json
dashboard/package-lock.json

