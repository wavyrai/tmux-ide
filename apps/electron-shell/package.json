{
  "name": "@tmux-ide/electron-shell",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "pnpm --filter @tmux-ide/desktop-renderer build && node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "lint": "eslint src scripts",
    "package": "pnpm build && node scripts/package.mjs",
    "package:smoke": "pnpm package && node scripts/smoke.mjs",
    "smoke": "pnpm build && electron . --smoke-test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tmux-ide/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^43.1.1",
    "esbuild": "0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
